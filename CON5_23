#include <bits/stdc++.h>
using namespace std;
//b1 sắp xếp dãy con tăng dài nhất 
//b2 số cách bằng n - lis (giữu đúng lis phần tử tăng dài nhất)
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n; cin >> n;
        int a[n];
        for(auto &x : a) cin >> x;
        vector<int> dp(n, 1);
        for(int i = 1; i<n;i++){
            for(int j = 0; j<i;j++){
                if((a[j] < a[i])){
                    dp[i] = max(dp[i], dp[j] + 1);
                }
            }
        }
        int result = *max_element(dp.begin(), dp.end());
        cout << n - result  <<endl;
    }

    return 0;
}
