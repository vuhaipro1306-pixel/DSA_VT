#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        long long n;
        cin >> n;

        vector<long long> a(n), f(n);
        for (long long i = 0; i < n; i++) cin >> a[i];

        f[0] = a[0];
        f[1] = max(a[0], a[1]); 

        for (long long i = 2; i < n; i++) {
            f[i] = max(f[i-1], f[i-2] + a[i]);
        }

        cout << f[n-1] << "\n"; //sô cuối cùng là max r
    }

    return 0;
}
