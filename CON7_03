#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;   
    cin.ignore();
    while (t--) {
        string s;
        getline(cin, s);
        stringstream ss(s);
        string token;
        stack<string> st;
        while(ss >> token){
            st.push(token);
        }
        vector<string> v;
        while(!st.empty()){
            string s1 = st.top();
            st.pop();
            reverse(s1.begin(), s1.end());
            v.push_back(s1);
        }
        reverse(v.begin(), v.end());
        for(auto x : v) cout << x <<" ";
        cout << endl;
    }

    return 0;
}
