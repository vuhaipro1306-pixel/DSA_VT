#include <bits/stdc++.h>
using namespace std;

struct Node {
    int data;
    Node *left, *right;

    Node(int x) {
        data = x;
        left = right = NULL;
    }
};

typedef Node* node;

//////////////////////////////////////////////////////
// BUILD TREE
//////////////////////////////////////////////////////

node buildTree(vector<int> &a) {

    if (a.empty() || a[0] == -1)
        return NULL;

    node root = new Node(a[0]);

    queue<node> q;
    q.push(root);

    int i = 1;

    while (!q.empty() && i < a.size()) {

        node cur = q.front();
        q.pop();

        // left
        if (i < a.size() && a[i] != -1) {
            cur->left = new Node(a[i]);
            q.push(cur->left);
        }
        i++;

        // right
        if (i < a.size() && a[i] != -1) {
            cur->right = new Node(a[i]);
            q.push(cur->right);
        }
        i++;
    }

    return root;
}

//////////////////////////////////////////////////////
// CLONE TREE
//////////////////////////////////////////////////////

node cloneTree(node root) {

    if (root == NULL)
        return NULL;

    node newRoot = new Node(root->data);

    newRoot->left = cloneTree(root->left);
    newRoot->right = cloneTree(root->right);

    return newRoot;
}


void inorder(node root, vector<int> &res) {

    if (root == NULL)
        return;

    inorder(root->left, res);

    res.push_back(root->data);

    inorder(root->right, res);
}


int main() {

    int t;
    cin >> t;
    cin.ignore();
    while (t--) {
        string s;
        getline(cin, s);
        stringstream ss(s);
        vector<int> a;
        int x;
        while (ss >> x)
            a.push_back(x);

        node root = buildTree(a);

        node cloneRoot = cloneTree(root);

        vector<int> res;
        inorder(cloneRoot, res);

        for (int i = 0; i < res.size(); i++) {

            cout << res[i];

            if (i != res.size() - 1)
                cout << " ";
        }

        cout << endl;
    }

    return 0;
}
