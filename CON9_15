#include <bits/stdc++.h>
using namespace std;
int check[1005];
vector<int> a[1005];
void dfs(int u){
    check[u] = 1;
    for(int x : a[u]){
        if(!check[x]) dfs(x);
    }
}
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int t;
    cin >> t;
    while(t--){
        int cnt = 0;
        memset(check,0,sizeof(check));
        int v, e;
        cin >> v >> e;
        for(int i = 1; i<= e; i++){
            int x, y;
            cin >> x >> y;
            a[x].push_back(y);
            a[y].push_back(x);
        }
        for(int i = 1; i<= v;i++){
            if(!check[i]){
                ++cnt;
                dfs(i);
            }
        }
        cout << cnt;
        cout << endl;
    }
}
