#include <bits/stdc++.h>
using namespace std;

int main(){
    int t; 
    cin >> t;

    while(t--){
        string s;
        cin >> s;

        stack<char> st1, st2;

        for(int i=0;i<s.size();i++){

            if(s[i] != ')'){
                st1.push(s[i]);

                if(s[i] == '('){
                    if(i>0 && s[i-1]=='-') st2.push('-');
                    else st2.push('+');
                }
            }

            else{ // phần tử s[i] == )
                string k="";

                while(st1.size()){
                    char c = st1.top(); st1.pop();
                    char d = st1.top(); st1.pop();

                    k = c + k;//-> mục đích chuyển về đúng thứ tự, càng ở trước ngăn xếp 
                    //càng đứng trước trong biểu thức

                    if(d=='(') break;

                    if( st2.top()=='-'){
                        if(d=='-') k = '+' + k;
                        else k = '-' + k;
                    }
                    else{
                        k = d + k;
                    }
                }

                st2.pop();

                for(char x : k) st1.push(x); //thêm ngược lại vào stack 
            }
        }

        string ans="";
        while(st1.size()){
            ans = st1.top() + ans;
            st1.pop();
        }

        cout << ans << endl;
    }
}
