#include <bits/stdc++.h>
using namespace std;
/*
ý tưởng: mỗi lần i tìm thằng lớn nhất từ i+1 tới n và swap với s[i], tiếp tục cho đến <= k
và chú ý ưu tiên thằng xa nhất để 10/10
*/
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int k;
        cin >> k;
        string s; cin >> s;
            for(int i = 0; i<s.size() && k > 0;i++){
                int pos = i;
                for(int j = i+1; j<s.size();j++){
                    if(s[j] >= s[pos]){ //phải có dấu bằng vì ưu tiên thằng xa nhất 
                      pos = j;
                    }
                }
                if(pos != i){
                    swap(s[i], s[pos]);
                    k--;
                }
            }
        cout << s << endl;
    }

    return 0;
}
