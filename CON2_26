#include <bits/stdc++.h>
using namespace std;
//chú ý sẽ có trường hợp tại vị trí đó nó là lớn nhất rồi -> không cần đổi chỗ -> k trừ k 
//và chú ý i đến giới hạn trước k
int main() {
    int t;
    cin >> t;

    while(t--) {
        int k;
        cin >> k;

        string s;
        cin >> s;

        int i = 0;

        while(k > 0 && i < s.size()) {

            int cnt = i;

            for(int j = i + 1; j < s.size(); j++) {
                if(s[j] >= s[cnt]) {
                    cnt = j;
                }
            }

            if(cnt != i) {
                swap(s[i], s[cnt]);
                k--;
            }

            i++;
        }

        cout << s << endl;
    }
}
