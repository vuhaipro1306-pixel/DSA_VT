#include <bits/stdc++.h>
using namespace std;
long long c[105];
void init(){
    c[0] = c[1] = 1;
    for(int i = 2; i<=101;i++){
        long long kq = 0;
        for(int j = 0; j<=i-1;j++){
            kq += c[j]*c[i-1-j];
        }
        c[i] = kq;
    }
}
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int t;
    cin >> t;
    init();
    while (t--) {
        int n; cin >> n;
        cout << c[n] << endl;
    }
    return 0;
}
