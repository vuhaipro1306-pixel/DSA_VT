#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int t;
    cin >> t;
    while (t--) {
        int n;
        cin >> n;
        queue<int> q;
        q.push(1);
        int cnt = 0;
        while(q.front() <= n){
            int temp = q.front();
            q.pop();
            ++cnt;
            q.push(temp * 10);
            q.push(temp * 10 + 1);
        }
        cout << cnt << endl;
    }

    return 0;
}
