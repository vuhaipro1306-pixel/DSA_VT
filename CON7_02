#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    cin.ignore();

    vector<int> v;
    string s;

    
        while(getline(cin, s)){

        if(s == "POP"){
            if(!v.empty()) v.pop_back();
        }
        else if(s == "PRINT"){
            if(!v.empty()) cout << v.back() << "\n";
            else cout << "NONE\n";
        }
        else{ // PUSH
            // int x = stoi(s.substr(5));
            v.push_back(stoi(s.substr(5)));
        }
    }

    return 0;
}
