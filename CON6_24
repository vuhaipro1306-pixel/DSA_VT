#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n , x;
        cin >> n >> x;
        int a[n];
        for(int i = 0; i<n;i++){
            cin >> a[i];
        }
        int l = 0, r = n-1;
        //cứ có l -> mid -1 tăng hoặc mid -> r tăng dùng binery
        while(l <= r){
            int mid = (l+r)/2;
            if(a[mid] == x) {
                cout << mid + 1 <<endl;
                break;
            }
            //nếu nửa trái tăng dần 
            if(a[l] <= a[mid]){
                if(x >= a[l] && x < a[mid]){
                    r = mid - 1;
                }
                else {
                    l = mid + 1;
                }
            }
            //nửa phải đã sort
            else{
                if(x > a[mid] && x <= a[r]){
                    l = mid + 1;
                }
                else
                     r = mid - 1;
                }
            }
        }
    return 0;
}
