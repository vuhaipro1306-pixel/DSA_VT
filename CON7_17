#include <bits/stdc++.h>
using namespace std;

int calc(char op, int a, int b) {
    if(op == '+') return a + b;
    if(op == '-') return a - b;
    if(op == '*') return a * b;
    if(op == '/'){
        if(b == 0) return 0;
        return a / b;
    }
    return 0;
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while(t--) {
        string s;
        cin >> s;
        stack<int> st;
        for(int i = s.size() - 1; i >= 0; i--) {  // duyệt từ phải sang trái
            if(isdigit(s[i])) {
                st.push(s[i] - '0');
            } else {
                int v1 = st.top(); st.pop();
                int v2 = st.top(); st.pop();
                st.push(calc(s[i], v1, v2)); // v1 trước v2 vì duyệt ngược
            }
        }
        cout << st.top() << "\n";
    }
    return 0;
}
