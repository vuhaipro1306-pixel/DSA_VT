#include <bits/stdc++.h>
using namespace std;
/* b1: tạo phần tử bên phải > và < qua 2 stack
b2: nếu b[i] tại đó bằng -1 và c[b[i]]tại đó bằng -1 thì in -1
*/
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n; cin >> n;
        vector <int> a(n), b(n,-1), c(n, -1);
        stack<int> st1, st2;
        for(int i = 0; i<n;i++) cin >> a[i];
        for(int i = 0; i<n;i++){
            while(!st1.empty() && a[i] > a[st1.top()]){
                b[st1.top()] = i;
                st1.pop();
            }
            st1.push(i);
        }
        for(int i = 0; i<n;i++){
            while(!st2.empty() && a[i] < a[st2.top()]){
                c[st2.top()] = i;
                st2.pop();
            }
            st2.push(i);
        }
        for(int i = 0; i<n;i++){
            if(b[i] == -1 || c[b[i]] == -1){
                cout << -1 << " ";
            }
            else cout << a[c[b[i]]] <<" ";
        }
        cout << endl;
    }

    return 0;
}
