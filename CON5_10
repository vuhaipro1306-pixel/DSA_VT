#include <bits/stdc++.h>
using namespace std;
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n, m; cin >> n >> m;
        vector<vector<int>> a(n+1, vector<int>(m+1));
        vector<vector<int>>dp(n+1, vector<int>(m+1, 1e9));
        for (int i = 1; i <= n; i++) {
            for (int j = 1; j <= m; j++) {
                cin >> a[i][j];
            }
        }
        dp[1][1] = a[1][1];
        for(int i = 1; i <=n;i++){
            for(int j = 1; j<=m;j++){
                if(i == 1 && j==1) continue;
                dp[i][j] = min({dp[i][j-1], dp[i-1][j-1], dp[i-1][j]}) + a[i][j];
            }
        }
        cout << dp[n][m] <<endl;
    }

    return 0;
}
