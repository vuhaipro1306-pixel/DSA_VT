#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int v,e; cin >> v >> e;
        vector<int> a[v+1];
        for(int i = 1; i<=e;i++){
            int x, y;
            cin >> x >> y;
            a[x].push_back(y);
        }
        for(int i = 1; i<=v;i++){
            cout << i <<": ";
            for(auto x : a[i]){
                cout << x << " ";
            }
            cout << endl;
        }
    }
    return 0;
}
