#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n; cin >> n;
        vector<int> a(n);
        for(auto &x : a) cin >> x;

        int dem = 0;

        for(int i = 0; i < n - 1; i++){
            int pos = i; 

            for(int j = i + 1; j < n; j++){ //tìm thằng bé nhất
                if(a[j] < a[pos]){
                    pos = j;
                }
            }

            if(pos != i){ // chỉ swap khi cần
                swap(a[i], a[pos]);
                ++dem;
            }
        }

        cout << dem << endl;
    }

    return 0;
}
