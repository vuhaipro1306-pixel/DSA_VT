#include <bits/stdc++.h>
using namespace std;
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n, s; cin >> n >> s;;
        int a[n];
        for(int &x : a) cin >> x;
        int f[s+1] = {0};
        f[0] = 1;
        for(int x : a){
            for(int j = s; j>= x; j--){
                if(f[j - x] == 1) f[j] = 1;
            }
        }
        if(f[s] == 1){
            cout << "YES\n";
        }
        else cout << "NO\n";
    }
    return 0;
}
