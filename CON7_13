#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        string s;
        cin >> s;
        stack<string>st;
        for(int i = s.size() - 1; i>= 0;i--){
            if(isalpha(s[i])){
                st.push(string(1,s[i]));
            }
            else {
                string v1 = st.top(); st.pop();
                string v2 = st.top(); st.pop();
                string v3 = v1 + v2 + s[i]; //s[i] là toán tử
                st.push(v3);
            }
        }
        cout << st.top() << endl;
    }

    return 0;
}
