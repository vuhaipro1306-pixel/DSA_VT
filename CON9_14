#include <bits/stdc++.h>
using namespace std;
vector<int> v[1005];
int check[1005];
int dem;
int cnt[1005];
void dfs(int u){
    check[u] = 1;
    cnt[u] = dem;
    for(int i : v[u]){
        if(!check[i]){
            dfs(i);
        }
    }
}
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int t;
    cin >> t;
    while (t--) {
        int n , m;
        cin >> n >> m;
        memset(check,0, sizeof(check));
        memset(cnt, 0 , sizeof(cnt));
        dem = 0;
        for(int i = 1; i<=m;i++){
            int x, y;
            cin >> x >> y;
            v[x].push_back(y);
            v[y].push_back(x);
        }
        for(int i = 1; i<=n;i++){
            if(!check[i]){
                ++dem;
                dfs(i);
            }
        }
        int q;
        cin >> q;
        while(q--){
            int a, b;
            cin >> a >> b;
            if(cnt[a] == cnt[b]){
                cout << "YES"<<endl;
            }
            else cout << "NO"<<endl;
        }
    }
    return 0;
}
