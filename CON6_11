#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n; cin >> n;
        int a[n];
        for(int &x : a) cin >> x;
        int res = 1e6;
        for(int i = 0; i<n-1; i++){
            for(int j= i+1; j<n;j++){
                if(abs(res) > abs(0-(a[i] + a[j]))){
                    res = a[i] + a[j];
                }
            }
        }
        cout << res << endl;
    }
    return 0;
}
