#include <bits/stdc++.h>
using namespace std;
/*
chú ý: chỉ được dịch ví dụ a[layer][x][y] -> a[layer+1][x][y]
*/
char a[35][35][35];
int d[35][35][35];
bool visited[35][35][35];

// 6 hướng trong không gian 3D
int dx[6] = {-1, 1, 0, 0, 0, 0};
int dy[6] = {0, 0, -1, 1, 0, 0};
int dz[6] = {0, 0, 0, 0, -1, 1};

int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;

    while(t--) {
        int A, B, C;
        cin >> A >> B >> C;

        queue<tuple<int,int,int>> q;

        // reset
        memset(visited, false, sizeof(visited));
        memset(d, 0, sizeof(d));

        // nhập dữ liệu
        for(int i = 0; i < A; i++) {
            for(int j = 0; j < B; j++) {
                for(int k = 0; k < C; k++) {
                    cin >> a[i][j][k];

                    if(a[i][j][k] == 'S') {
                        q.push({i, j, k});
                        visited[i][j][k] = true;
                    }
                }
            }
        }

        int ans = -1;

        // BFS
        while(!q.empty()) {
            auto [x, y, z] = q.front();
            q.pop();

            if(a[x][y][z] == 'E') {
                ans = d[x][y][z];
                break;
            }

            for(int i = 0; i < 6; i++) {
                int nx = x + dx[i];
                int ny = y + dy[i];
                int nz = z + dz[i];

                if(nx >= 0 && nx < A &&
                   ny >= 0 && ny < B &&
                   nz >= 0 && nz < C &&
                   !visited[nx][ny][nz] &&
                   a[nx][ny][nz] != '#') {

                    visited[nx][ny][nz] = true;
                    d[nx][ny][nz] = d[x][y][z] + 1;

                    q.push({nx, ny, nz});
                }
            }
        }

        cout << ans << '\n';
    }

    return 0;
}
