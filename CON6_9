#include <bits/stdc++.h>
using namespace std;
/*
với mỗi a[i] tôi cần tìm số nào để ghép với tôi ra k need = k - a[i];
với mỗi số xuất hiện trước đó có bao nhiêu số = need
*/
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n, k; cin >> n >> k;
        vector<int> v(n);
        for(int &x : v) cin >> x;
        sort(v.begin(), v.end());
        map<int, int> mp;
        int res = 0;
        for(int i = 0; i<n && v[i] <= k;i++){
            int need = k - v[i];
            if(mp.count(need)){ //need đã có trước đó
                res += mp[need];
            }
            mp[v[i]]++;
        }
        cout << res <<endl;
    }

    return 0;
}
