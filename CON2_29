#include <bits/stdc++.h>
using namespace std;
int main(){
    int t; cin >> t;
    while(t--){
        int n, m; cin >> n >> m;
        int a[n+1][m+1];
        int dp[n+1][m+1]; //số cách đi tới ô i, j 
        for(int i = 0; i<=m;i++){
            dp[0][i] = 0;
        }
        for(int i = 0; i<=n;i++){
            dp[i][0] = 0;
        }
        for(int i = 1; i<=n;i++){
            for(int j = 1; j<=m;j++){
                cin >> a[i][j];
            }
        }
        for(int i = 1; i <= n;i++){
            for(int j = 1; j<=m;j++){
                if(i == 1 && j == 1) dp[i][j] = 1;
                else{
                    dp[i][j] = dp[i-1][j] + dp[i][j-1]; //tại ô thí i j thì ô đằng trước nó là i và j -1 và trên nó là i-1 j 
                }
            }
        }
        cout << dp[n][m] <<endl;
    }
}
