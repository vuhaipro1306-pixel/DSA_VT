#include <bits/stdc++.h>
using namespace std;

vector<int> adj[1005];
int check[1005];
int deg[1005];
int cnt[1005];
int dem;

void dfs(int i){
    check[i] = 1;
    cnt[i] = dem;
    for(int u : adj[i]) {
        if(!check[u]) dfs(u);
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {

        int v, e;
        cin >> v >> e;

        dem = 0;
        memset(check, 0, sizeof(check));
        memset(deg, 0, sizeof(deg));
        memset(cnt, 0, sizeof(cnt));

        // ❗ reset danh sách kề
        for(int i = 1; i <= v; i++) adj[i].clear();

        for(int i = 1; i<= e;i++){
            int x, y;
            cin >> x >> y;
            adj[x].push_back(y);
            adj[y].push_back(x);
            deg[x]++; 
            deg[y]++;
        }

        for(int i = 1; i<=v;i++){
            if(!check[i]){
                ++dem;
                dfs(i);
            }
        }

        int ket_qua = 2;
        int dinh_bac_le = 0;

        for(int i = 1; i<=v;i++){

            if(deg[i] % 2 != 0){
                dinh_bac_le++;
            }

            if(deg[i] != 0 && cnt[i] != cnt[1]){
                ket_qua = 0;
                break;
            }
        }

        if(ket_qua != 0){
            if(dinh_bac_le == 0) ket_qua = 2;
            else if(dinh_bac_le == 2) ket_qua = 1;
            else ket_qua = 0;
        }

        cout << ket_qua << endl;
    }

    return 0;
}
