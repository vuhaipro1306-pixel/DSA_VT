#include <bits/stdc++.h>
using namespace std;
struct Node {
    int val;
    Node *left, *right;
    Node(int x){
        val = x;
        left = right = NULL;
    }
};
typedef Node* node;
void makeNode(node root, int x, int y, char c){
    if(c == 'L'){
        root -> left = new Node(y);
    }
    else root -> right = new Node(y);
}
void Insert(node root, int x, int y, char c){
    if(root == NULL) return;
    if(root -> val == x){
        makeNode(root, x, y, c);
        return;
    }
    Insert(root -> left, x, y, c);
    Insert(root -> right, x, y, c);
}

int height(node root){
    if(root == NULL) return 0;
    return 1 + max(height(root -> left),height(root ->right));
}

bool check (node root, int h, int level){
    if(root == NULL) return 1;
    if(root -> left == NULL && root -> right == NULL &&  level < h) return 0;
    return check(root -> left, h, level + 1) && check(root -> right, h, level + 1);
}
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int t;
    cin >> t;
    while (t--) {
        int n; cin >> n;
        node root = NULL;
        while(n--){
            int x, y; char c;
            cin >> x >> y >> c;
            if(root == NULL){
                root = new Node(x);
                makeNode(root, x, y, c);
            }
            else Insert(root, x, y, c);
        }
        int h = height(root);
        bool cnt = check(root,h,1); //bắt đầu từ 1 vì 1 -> 2 thì height = 2
        if(cnt) cout << 1 <<endl;
        else cout << 0 <<endl;
    }
    return 0;
}
