#include <bits/stdc++.h>
using namespace std;
using ll = long long;
ll Mod = 1e9 + 7;
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        ll n; cin >> n;
        ll ans = 0;
        priority_queue<ll, vector<ll>, greater<ll>>q;
        for(ll i = 0; i<n;i++){ 
            ll x;
            cin >> x;
            q.push(x);
        }
        while(q.size() > 1){
            ll top1 = q.top(); q.pop();
            ll top2 = q.top(); q.pop();
            ans = (ans + top1 + top2) % Mod;
            q.push((top1 + top2)%Mod);
        }
        cout << ans <<endl;
    }

    return 0;
}
