#include <bits/stdc++.h>
using namespace std;
int n;
int a[100];
void in_ketqua(){
    for(int i = 0; i<n;i++){
        if(a[i] == 0){
            cout << "A";
        }
        else cout << "B";
    }
    cout << " ";
}
void sinh(int i){
    for(int j = 0; j<=1;j++){
        a[i] = j;
        if(i == n-1){
            in_ketqua();
        }
        else {
            sinh(i+1);
        }
    }
}
int main(){
    int t; cin >> t;
    while(t--){
        cin >> n;
        //in_ketqua();
        sinh(0);
        cout << endl;
    }
}
