#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n; cin >> n;
        int a[n];
        for(int &x : a) cin >> x;
        map<int, int> mp;
        for(int x : a){
            while(x){
                int k = x % 10;
                mp[k]++;
                x /= 10;
            }
        }
        for(auto x : mp){
            cout << x.first <<" ";
        }
        cout << endl;
    }

    return 0;
}
