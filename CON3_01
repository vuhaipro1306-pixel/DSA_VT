#include <bits/stdc++.h>
using namespace std;
/* luôn đổi tiền từ phần tử lớn nhất
*/
int main(){
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;

    int a[] = {1000,500,200,100,50,20,10,5,2,1};

    while(t--){
        int n;
        cin >> n;

        int cnt = 0;

        for(int i = 0; i < 10; i++){
            cnt += n / a[i];
            n %= a[i];
        }

        cout << cnt << "\n";
    }
}
