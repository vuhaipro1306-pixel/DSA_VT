#include <bits/stdc++.h>
using namespace std;

vector<int> a[1005];
int check[1005];

void dfs(int u){
    check[u] = 1;
    for(int v : a[u]){
        if(!check[v]) dfs(v);
    }
}

int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;

    while(t--){
        memset(check,0,sizeof(check));
        int n;
        cin >> n;
        for(int i=1;i<=n;i++) a[i].clear(); //bắt buộc phải xóa mảng kề đi 
        for(int i=1;i<n;i++){
            int x,y;
            cin >> x >> y;
            a[x].push_back(y);
            a[y].push_back(x);
        }

        dfs(1);

        bool ok = true;
        for(int i=1;i<=n;i++){
            if(!check[i]){
                ok = false;
                break;
            }
        }

        if(ok) cout << "YES\n";
        else cout << "NO\n";
    }
}
