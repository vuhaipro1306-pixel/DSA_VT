#include <bits/stdc++.h>
using namespace std;
//d[j] tổng lớn nhất <= j
/*
xét 1 con bò -> nếu không lấy d[j] giữ nguyên 
            -> nếu lấy dp[j] = dp[j-w[i]] + w[i]
*/
int main() {
    int t;
    cin >> t;
    while(t--){
    int c, n;
    cin >> c >> n;
    int a[n];
    for(auto &x : a) cin >> x;
    vector<int> dp(c+1, 0);
    for(auto x : a){
        for(int i = c; i >= x; i--){
            dp[i] = max(dp[i], dp[i-x] + x); //dp[i] không chọn, 
            //nếu chọn thì cần xem tổng lớn nhất dp[i-a[i]] xong + a[i] -> chọn con lợn đó
        }
    }
    cout << dp[c] <<endl;
    }
}
