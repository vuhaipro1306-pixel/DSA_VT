#include <bits/stdc++.h>
using namespace std;
/*
nếu gặp [ thì ++cnt 
gặp ] thì cộng ++cnt2
nếu cnt2 > cnt1 thì tìm thằng đầu tiên từ vị trí đó bằng [ và swap nó do chỉ được đổi chỗ liên tiếp
số lần đổi chỗ sẽ là j - i lần
*/
int res;
void check(string s){
    int cnt1 = 0;
    int cnt2 = 0;
    for(int i = 0; i<s.size();i++){
        if(s[i] == '[') ++cnt1;
        else ++cnt2;
        if(cnt2 > cnt1){
            for(int j = i+1; j <s.size(); j++){
                if(s[j] == '['){
                    res += (j-i);
                    swap(s[j], s[i]);
                    ++cnt1;
                    --cnt2;
                    break;
                }
            }
        }
    }
}
int main(){
    int t; cin >> t;
    while(t--){
        string s; cin >> s;
        res = 0;
        check(s);
        cout << res <<endl;
    }
}
