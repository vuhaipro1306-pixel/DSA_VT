#include <bits/stdc++.h>
using namespace std;
//xet phuong trinh 4a+7b = n
/*
b1: uuw tiên số có ít chỗ số hơn trước -> nhiều số 7 nhất từ đầu -> số ít chữ số nhất
b2: nếu có cùng chữ số thì in ra chuỗi có nhiều số 4 nhất trước 
vd 7744, 7474,.. thì ta in 4477
*/

int main (){
    int t; cin >> t;
    while(t--){
    int n; cin >> n;
    int check = 0;
    for(int i = n/7;i>=0;i--){
        if((n-7*i) % 4 == 0){
            int a = (n-7*i) / 4;
            for(int j = 0; j<a;j++){
                cout << 4;
            }
            for(int j = 0; j<i;j++) cout << 7;
            check = 1;
            break;
        }
    }
    if(check == 0) cout << -1;
    cout << endl;
    }
}
