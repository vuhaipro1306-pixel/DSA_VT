#include <bits/stdc++.h>
using namespace std;
int MOD = 1e9+7;
//tính các hoán vị 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n, k; cin >> n >>k; //tối đa k bước
        long long dp[n+1]= {0};//số cách để bước đến bậc thứ i 
        dp[0] = 1; //0 bậc thfi chỉ có 1 cách là 0 bước bậc nào
        for(int i = 1; i<=n;i++){
            for(int j = 1; j<=k && i <= n;j++){
                if(i - j == 0){
                    dp[i]++;
                }
                else if(i - j > 0){
                    dp[i] = (dp[i] + dp[i-j]) % MOD;
                }
            }
        }
        cout << dp[n]<<endl;
    }

    return 0;
}
