#include <bits/stdc++.h>
using namespace std;
long long dp[1005][1005];
int const MOD = 1e9+7;
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n, k; cin >> n >> k;
        memset(dp, 0, sizeof(dp));
        for(int i = 0; i<= n;i++){ //i là số phần tử, j là số phần tử được chọn
            for(int j = 0; j <= i;j++){
                if(j == 0 || i  == j ){
                    dp[i][j] = 1;
                }
                else{
                    dp[i][j] = (dp[i-1][j-1] + dp[i-1][j]) % MOD;
                }
            }
        }
        cout << dp[n][k] <<endl;
    }

    return 0;
}
