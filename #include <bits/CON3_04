#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;

    while (t--) {
        int n;
        cin >> n;

        vector<int> a;

        for(int i = 0; i < n; i++){
            int x;
            cin >> x;
            a.push_back(x);
        }

        sort(a.begin(), a.end());

        long long x = 0, y = 0;

        for(int i = 0; i < a.size(); i++){
            if(i % 2 == 0)
                x = x * 10 + a[i];
            else
                y = y * 10 + a[i];
        }

        cout << x + y << "\n";
    }

    return 0;
}
