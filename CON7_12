#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        string s;
        cin >> s;
        stack<string> q;

        for (int i = s.size() - 1; i >= 0; i--) {
            if (isalpha(s[i])) {
                q.push(string(1, s[i]));  // ✅ sửa ở đây
            } else {
                string k1 = q.top(); q.pop();
                string k2 = q.top(); q.pop();
                string v = k1 + s[i] + k2;
                q.push("(" + v + ")");
            }
        }
        cout << q.top() << endl;
    }
    return 0;
}
