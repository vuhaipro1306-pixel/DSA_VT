#include <bits/stdc++.h>
using namespace std;
int main(){
    int t; cin >> t;
    while(t--){
        int n; cin >> n;
        int a[n];
        for(int i = 0; i<n;i++){
            cin >> a[i];
        }
        int j = n-1-1;
        while(j >= 0 && a[j] >= a[j+1]){
            --j;
        }
        if(j < 0){
            reverse(a, a+n);
            for(int x : a) cout << x << " ";
            cout << endl;
        }
        else {
            int i = n-1;
            while(a[i] < a[j]){
   				--i;
            }
            swap(a[i], a[j]);
            reverse(a+j+1, a+n);
            for(auto x : a) cout << x << " ";
            cout << endl;
        }
    }
    return 0;
	}
