#include <bits/stdc++.h>
using namespace std;
int n, k;
int a[20];
vector<vector<int>> res; //vector lưu kq
vector<int> v;
void Try(int start, int tong){
    if(tong == k){
        res.push_back(v);
        return;
    }
    for(int i = start; i<n;i++){
        if(tong + a[i] <= k){
            v.push_back(a[i]);
            Try(i+1, tong + a[i]);
            v.pop_back();
        }
    }
}
int main(){
    int t; cin >> t;
    while(t--){
        cin >> n >> k;
        for(int i = 0; i<n;i++)
            cin >> a[i];
        sort(a, a+n);
        res.clear();
        v.clear();
        Try(0,0);
        if(res.empty()){
            cout << -1 << endl;
            continue;
        }
        for(int i= 0; i<res.size();i++){
            cout << "[";
            for(int j = 0; j<res[i].size(); j++){
                if(j == res[i].size() - 1){
                    cout << res[i][j];
                }
                else cout << res[i][j] <<" ";
            }
            cout << "] ";
        }
        cout << endl;
    }
    
}
