/*
    ở vị trí i thì chỉ có thể swap cho vị trí (n-1) - i;
    b1; tạo 1 mảng B là mảng A đã sắp xếp;
    b2; cặp phần tử {a[i], a[n-1-i]} phawni đúng với thứ tự trong mảng đã sắp xếp {b[i], b[n-1-i]}
    vd đề bài: A = [1 6 3 4 5 2 7] -> B = [1 2 3 4 5 6 7]
    (0,6) → {1,7} = {1,7} ✓
    (1,5) → {6,2} = {2,6} ✓
    (2,4) → {3,5} = {3,5} ✓
    không thể:
A = [3 1 2]
sorted:
[1 2 3]
cặp:
(0,2) → {3,2}
sorted → {1,3}
*/
#include <bits/stdc++.h>
using namespace std;
int main(){
    int t;
    cin >> t;
    while(t--){
        int n;
        cin >> n;
        int a[n];
        for(int &x : a) cin >> x;
        vector<int> b(a, a+n);
        sort(b.begin(), b.end());
        bool ok = true;
        int mid = (n-1)/2;
        for(int i = 0; i < mid; i++){
            set<int> x = {a[i], a[n-1-i]};
            set<int> y = {b[i], b[n-1-i]};
            if(x != y){
                ok = false;
                break;
            }
        }
        
        if(ok) cout << "Yes\n";
        else cout << "No\n";
    }
}
