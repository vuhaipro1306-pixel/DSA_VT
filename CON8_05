#include <bits/stdc++.h>
using namespace std;
vector<string> v;
void init(){
    v.push_back("1");
    queue<string> q;
    q.push("1");
    for(int i = 1; i<10005;i++){
        string top = q.front();
        q.push(top +"0");
        q.push(top+"1");
        v.push_back(top + "0");
        v.push_back(top + "1");
        q.pop();
    }
}
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    init();
    int t;
    cin >> t;
    while (t--) {
        int n; cin >> n;
        for(int i = 0; i<n;i++){
            cout << v[i] <<" ";
        }    
        cout << endl;
    }

    return 0;
}
