#include <bits/stdc++.h> 
using namespace std;
int cnt;
int n, a[100], cc ;
void ktao(){
    cnt = 1;
    a[1] = n;
}

void sinh(){
    int i = cnt;
    while(i >= 1 && a[i] == 1){
        --i;
    }
    if(i == 0) cc = 1;
    else {
        a[i]--;
        int d = cnt - i + 1;//vì đã giảm
        int q = d / a[i],  r = d % a[i];
        cnt = i;
        if(q){
            for(int j = 1; j <= q; j++){
                ++cnt;
                a[cnt] = a[i];
            }
        }
        if(r){
            ++cnt;
            a[cnt] = r;
        }
    }
}
int main(){
    int t; cin >> t;
    while(t--){
       cin >> n;
        cc= 0;
        ktao();
        while(!cc){
            cout << "(";
            for(int i = 1; i<=cnt;i++){
                if(i == cnt) cout << a[i];
                else cout << a[i] <<" ";
            }
            cout << ") ";
            sinh();
        }
        cout << endl;
    }
}
