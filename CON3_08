#include <bits/stdc++.h>
using namespace std;

bool cmp( pair<int,int> &a,  pair<int,int> &b){ //hoặc k cần &
  	 return a.second < b.second; //buocj phải như này mới đúng kk nếu if(a.second ! b.second) return -> 9/10
}

int main(){
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;

    while(t--){
        int n;
        cin >> n;

        vector<int> si(n), fi(n);
        vector<pair<int,int>> v(n);

        for(int &x : si) cin >> x;
        for(int &x : fi) cin >> x;

        for(int i=0;i<n;i++){
            v[i] = {si[i], fi[i]};
        }

        sort(v.begin(), v.end(), cmp);

        int cnt = 1;
        int parent = v[0].second;

        for(int i=1;i<n;i++){
            if(v[i].first >= parent){
                cnt++;
                parent = v[i].second;
            }
        }

        cout << cnt << "\n";
    }
}
