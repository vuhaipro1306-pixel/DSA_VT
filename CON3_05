#include <bits/stdc++.h>
using namespace std;
int main (){
    int t; cin >> t;
    while(t--){
        int n, k; cin >> n >> k;
        int a[n];
        long long total = 0, sum1 = 0, sum2 = 0;
        for(auto &x : a) {
            cin >> x;
            total += x;
        }
        sort(a, a+n);
        for(int i = 0; i<k;i++){
            sum1 += a[i];
        }
        for(int i = 0; i<n-k;i++){
            sum2 += a[i];
        }
        cout << max(abs(total - sum1 - sum1), abs(total-sum2 -sum2));
        cout << endl;
    }
}
