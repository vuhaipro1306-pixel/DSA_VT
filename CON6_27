#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n; cin >> n;
        int a[n];
        for(auto &x : a) cin >> x;
        vector<vector<int>> v;
        v.push_back({a[0]});
        for(int i = 1; i<n;i++){
           int j = i;
           while(j > 0 && a[j] < a[j-1]){
                swap(a[j], a[j-1]);
                --j;
           }
           v.push_back({a, a+i+1}); 
        }
        for(int i = 0; i<v.size();i++){
            cout << "Buoc "<<i<<": ";
            for(auto x : v[i]){
                cout << x << " ";
            }
            cout << endl;
        }
    }

    return 0;
}
