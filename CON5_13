int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    vector<long long> v(10001);
    v[0] = 1;

    int i2 = 0, i3 = 0, i5 = 0;

    for(int i = 1; i < 10001; i++){
        long long next2 = v[i2] * 2;
        long long next3 = v[i3] * 3;
        long long next5 = v[i5] * 5;

        v[i] = min({next2, next3, next5});

        if(v[i] == next2) i2++;
        if(v[i] == next3) i3++;
        if(v[i] == next5) i5++;
    }

    int t; cin >> t;
    while(t--){
        int n; cin >> n;
        cout << v[n-1] << '\n';
    }
}
