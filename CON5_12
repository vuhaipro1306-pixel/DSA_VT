#include <bits/stdc++.h>
using namespace std;
int const MOD = 1e9+7;
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n, k; cin >> n >> k;
        long long kq = 1;
        for(int i = 0; i<k;i++){
            kq = (kq % MOD * ((n-i) % MOD)) % MOD;
        }
        cout << kq << endl;
    }
    return 0;
}
