#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n; cin >> n;
        int a[n]; 
        for(auto &x : a) cin >> x;
        for(int i = 0; i<n-1;i++){
            cout << "Buoc " <<i+1<<": ";
            for(int j = i+1; j<n;j++){
                if(a[j] < a[i]){
                    swap(a[j], a[i]);
                }
            }
            for(auto x : a){
                cout << x <<" ";
            }
            cout << endl;
        }
    }

    return 0;
}
